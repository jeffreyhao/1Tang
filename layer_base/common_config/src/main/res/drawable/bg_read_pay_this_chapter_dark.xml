<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:startColor="#fff5efff"
                android:centerColor="#fffcfbff"
                android:endColor="#fff5efff"
                android:angle="180"
                />
            <stroke
                android:width="2dp"
                android:color="#ff5913d0"
                />
            <corners
                android:radius="17dp"
                />
        </shape>
    </item>

    <item android:state_selected="false">
        <shape android:shape="rectangle">
            <solid
                android:color="#ffffffff"
                />
            <stroke
                android:width="1dp"
                android:color="#ffefefef"
                />
            <corners
                android:radius="17dp"
                />
        </shape>
    </item>

</selector>



