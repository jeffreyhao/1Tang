<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/book_detail_recom_book1"
    android:layout_width="96dp"
    android:layout_marginEnd="20dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    tools:background="#3333">

    <androidx.cardview.widget.CardView
        android:layout_width="96dp"
        android:layout_height="128dp"
        app:cardElevation="0dp"
        app:cardCornerRadius="6dp">
        <ImageView
            android:id="@+id/iv_cover"
            android:layout_width="96dp"
            android:layout_height="match_parent"
            android:src="@drawable/default_bg_vertical"/>
        <View
            android:background="@drawable/book_cover_radius_2dp"
            android:layout_width="96dp"
            android:layout_height="match_parent"/>
        <ImageView
            android:id="@+id/iv_premium"
            android:visibility="gone"
            android:layout_gravity="end"
            android:src="@drawable/ic_book_premium"
            android:layout_width="48dp"
            android:layout_height="15.7dp"
            tools:visibility="visible"
            />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/book_detail_recom_book_name1"
        android:layout_marginTop="7dp"
        android:textStyle="bold"
        android:textColor="@color/pp_color_333333"
        android:textSize="13sp"
        android:background="@color/transparent"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        tools:text="title"/>
</LinearLayout>