<?xml version="1.0" encoding="utf-8"?>
<layout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    >
    <!-- 支付墙 -->
    <LinearLayout
        android:id="@+id/paywall_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:background="@drawable/bg_short_read_recharge_day"
        tools:layout_marginHorizontal="10dp"
        tools:elevation="10dp"
        tools:visibility="visible"
        >
        <com.baidu.baselibrary.widget.GradientTextView
            android:id="@+id/pay_wall_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="23dp"
            android:layout_marginHorizontal="50dp"
            android:textColor="@color/colorAccent"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            android:textSize="26dp"
            android:textStyle="bold"
            android:text="@string/next_chapter_waiting"
            />
        <TextView
            android:id="@+id/pay_wall_tip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="20dp"
            android:layout_marginHorizontal="60dp"
            android:gravity="center_horizontal"
            android:textColor="#333333"
            android:textSize="12dp"
            android:text="@string/continue_read_long"
            />
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            >
            <ImageView
                android:id="@+id/pay_wall_avatars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_premium_avatars"
                />
            <TextView
                android:id="@+id/pay_wall_readers"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_toRightOf="@+id/pay_wall_avatars"
                android:textColor="#999999"
                android:textSize="12dp"
                android:text="@string/trust_readers"
                />
            <ImageView
                android:id="@+id/pay_wall_ratings"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="1dp"
                android:src="@drawable/ic_short_rating_stars"
                android:layout_toRightOf="@+id/pay_wall_avatars"
                android:layout_alignBottom="@+id/pay_wall_avatars"
                />
            <TextView
                android:id="@+id/pay_wall_rate_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:layout_toRightOf="@+id/pay_wall_ratings"
                android:layout_alignBottom="@+id/pay_wall_avatars"
                android:textColor="#999999"
                android:textSize="12dp"
                android:text="5.0"
                />
        </RelativeLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="30dp"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            >
            <TextView
                android:id="@+id/tv_pay_wall_keep"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_light_keep_reading"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="12dp"
                android:text="@string/keep_reading"
                />
            <TextView
                android:id="@+id/tv_pay_wall_no_interrupt"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_light_no_interruptions"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="12dp"
                android:text="@string/no_Interruptions"
                />
            <TextView
                android:id="@+id/tv_pay_wall_story_num"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableTop="@drawable/ic_light_stories_num"
                android:gravity="center"
                android:textColor="#333333"
                android:textSize="12dp"
                android:text="@string/stories_num"
                />
        </LinearLayout>
        <TextView
            android:id="@+id/tv_unlock_short"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="30dp"
            android:background="@drawable/common_button_background"
            android:gravity="center"
            android:textColor="@color/white"
            android:textSize="15dp"
            android:textStyle="bold"
            android:text="@string/continue_story"
            />
    </LinearLayout>
</layout>